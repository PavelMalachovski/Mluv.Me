### Метрики
- Время обработки голосовых (Railway Observability)
- Количество запросов к OpenAI
- Стоимость API вызовов
- Активные пользователи (DAU)
- Railway встроенный мониторинг CPU/Memory/Network

# === ПРИМЕРЫ КОДА ===

## Backend: Личность Хонзика

```python
# services/honzik_personality.py
from openai import AsyncOpenAI
from typing import Optional

class HonzikPersonality:
    """Личность Хонзика - веселого чешского собеседника."""

    def __init__(self, openai_client: AsyncOpenAI):
        self.client = openai_client
        self.base_prompt = HONZIK_BASE_PROMPT

    async def generate_response(
        self,
        user_text: str,
        style: str,
        level: str,
        corrections_level: str,
        ui_language: str,
        conversation_history: list[dict],
    ) -> dict:
        """
        Генерация ответа Хонзика с исправлениями.

        Args:
            user_text: Текст пользователя на чешском
            style: Стиль общения (friendly/tutor/casual)
            level: Уровень чешского
            corrections_level: Уровень исправлений
            ui_language: Язык интерфейса (ru/uk)
            conversation_history: История разговора

        Returns:
            dict: Ответ с исправлениями и оценкой
        """
        prompt = self._build_prompt(
            user_text=user_text,
            style=style,
            level=level,
            corrections_level=corrections_level,
            ui_language=ui_language,
            conversation_history=conversation_history
        )

        response = await self.client.chat.completions.create(
            model="gpt-4o",
            messages=[
                {"role": "system", "content": prompt},
                {"role": "user", "content": user_text}
            ],
            response_format={"type": "json_object"},
            temperature=0.8  # Чуть выше для более живых ответов
        )

        return json.loads(response.choices[0].message.content)
```

## Bot: Обработка голосового с локализацией

```python
# bot/handlers/voice.py
from aiogram import Router, F
from aiogram.types import Message
from services.api_client import APIClient
from localization import get_text

router = Router()

@router.message(F.voice)
async def handle_voice(message: Message, api_client: APIClient):
    """Обработка голосового сообщения."""
    user = await api_client.get_user(message.from_user.id)

    # Показать что Хонзик записывает ответ
    await message.bot.send_chat_action(
        chat_id=message.chat.id,
        action="record_voice"
    )

    # Скачать файл
    file = await message.bot.get_file(message.voice.file_id)
    audio_bytes = await message.bot.download_file(file.file_path)

    # Отправить в backend
    response = await api_client.process_voice(
        user_id=message.from_user.id,
        audio=audio_bytes
    )

    # Отправить голосовой ответ Хонзика
    caption = f"✅ {response.correctness_score}% | 🔥 Streak: {response.streak}"
    await message.answer_voice(
        voice=response.audio_response,
        caption=caption
    )

    # Показать исправления
    if response.corrections.mistakes:
        corrections_text = format_corrections(
            response.corrections,
            user.ui_language
        )
        await message.answer(corrections_text)

    # Если заработали звезды
    if response.stars_earned > 0:
        stars_text = get_text("stars_earned", user.ui_language)
        await message.answer(
            f"⭐ {stars_text}: +{response.stars_earned}"
        )
```

